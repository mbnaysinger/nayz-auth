# Copie para nayz-auth.env, preencha e proteja: chmod 600 env/nayz-auth.env
# NUNCA commite o arquivo real.

# Banco existente da VPS (host.docker.internal = host da VPS visto de dentro do container)
DATABASE_URL=postgres://usuario:senha@host.docker.internal:5432/nayz_auth?sslmode=require

# Segredo forte (ex.: openssl rand -base64 48) — IDÊNTICO ao das APIs que validam o JWT
JWT_SECRET=

REDIS_URL=redis:6379

# SMTP para o fluxo passwordless (opcional em primeiro momento)
SMTP_HOST=
SMTP_PORT=587
